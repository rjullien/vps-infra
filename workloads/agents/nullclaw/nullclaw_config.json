{
  "models": {
    "providers": {
      "bifrost": {
        "base_url": "http://bifrost.openclaw.svc.cluster.local:8080/v1",
        "api_key": "dummy"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "bifrost/openai/MiniMaxAI/MiniMax-M2.5-TEE"
      }
    }
  },
  "model_routes": [
    {
      "hint": "fast",
      "provider": "bifrost",
      "model": "gemini/gemini-3.1-flash-lite-preview",
      "cost_class": "free"
    },
    {
      "hint": "balanced",
      "provider": "bifrost",
      "model": "openai/MiniMaxAI/MiniMax-M2.5-TEE",
      "cost_class": "cheap"
    },
    {
      "hint": "deep",
      "provider": "bifrost",
      "model": "openai/moonshotai/Kimi-K2.5-TEE",
      "cost_class": "standard"
    },
    {
      "hint": "vision",
      "provider": "bifrost",
      "model": "gemini/gemini-3.1-flash-lite-preview",
      "cost_class": "free"
    }
  ],
  "channels": {
    "telegram": {
      "accounts": {
        "main": {
          "bot_token": "${TELEGRAM_BOT_TOKEN}",
          "allow_from": ["974020023", "8348834293"],
          "require_mention": true
        }
      }
    }
  },
  "memory": {
    "backend": "sqlite",
    "auto_save": true,
    "citations": "auto",
    "search": {
      "enabled": true,
      "provider": "custom:http://bifrost.openclaw.svc.cluster.local:8080/v1",
      "model": "bedrock/amazon.titan-embed-text-v2:0",
      "store": {
        "kind": "ann"
      },
      "query": {
        "max_results": 6,
        "min_score": 0.0,
        "merge_strategy": "rrf",
        "rrf_k": 60,
        "hybrid": {
          "enabled": true,
          "vector_weight": 0.7,
          "text_weight": 0.3,
          "candidate_multiplier": 4,
          "mmr": { "enabled": true, "lambda": 0.7 },
          "temporal_decay": { "enabled": true, "half_life_days": 30 }
        }
      },
      "chunking": {
        "max_tokens": 512,
        "overlap": 64
      },
      "sync": {
        "mode": "best_effort",
        "embed_timeout_ms": 15000,
        "vector_timeout_ms": 5000,
        "embed_max_retries": 2,
        "vector_max_retries": 2
      },
      "cache": {
        "enabled": true,
        "max_entries": 10000
      }
    },
    "qmd": {
      "enabled": false,
      "command": "qmd",
      "search_mode": "search",
      "include_default_memory": true
    },
    "lifecycle": {
      "hygiene_enabled": true,
      "archive_after_days": 7,
      "purge_after_days": 30,
      "preserve_before_purge": true,
      "conversation_retention_days": 30,
      "snapshot_enabled": false,
      "snapshot_on_hygiene": false,
      "auto_hydrate": true
    },
    "response_cache": {
      "enabled": true,
      "ttl_minutes": 60,
      "max_entries": 5000
    },
    "summarizer": {
      "enabled": true,
      "window_size_tokens": 4000,
      "summary_max_tokens": 500,
      "auto_extract_semantic": true
    },
    "retrieval_stages": {
      "query_expansion_enabled": true,
      "adaptive_retrieval_enabled": true,
      "adaptive_keyword_max_tokens": 3,
      "adaptive_vector_min_tokens": 6,
      "llm_reranker_enabled": true,
      "llm_reranker_max_candidates": 10,
      "llm_reranker_timeout_ms": 5000
    },
    "reliability": {
      "rollout_mode": "off",
      "circuit_breaker_failures": 5,
      "circuit_breaker_cooldown_ms": 30000,
      "shadow_hybrid_percent": 0,
      "canary_hybrid_percent": 0,
      "fallback_policy": "degrade"
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 3000,
    "require_pairing": false
  },
  "autonomy": {
    "level": "full",
    "workspace_only": true,
    "max_actions_per_hour": 1000,
    "allowed_commands": ["*"],
    "allowed_paths": ["*"],
    "require_approval_for_medium_risk": false,
    "block_high_risk_commands": false,
    "allow_raw_url_chars": true
  },
  "http_request": {
    "enabled": true,
    "max_response_size": 1000000,
    "timeout_secs": 120,
    "allowed_domains": [],
    "search_base_url": null,
    "search_provider": "jina",
    "search_fallback_providers": ["jina", "duckduckgo"]
  },
  "reliability": {
    "provider_retries": 2,
    "provider_backoff_ms": 500
  },
  "a2a": {
    "enabled": false,
    "name": "NullClaw",
    "description": "AI assistant",
    "url": "https://agent.example.com",
    "version": "1.0.0"
  },
  "security": {
    "sandbox": {
      "backend": "auto"
    },
    "audit": {
      "enabled": true
    }
  }
}
